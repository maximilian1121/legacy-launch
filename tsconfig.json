{
    "compilerOptions": {
        "target": "ES6",
        "jsx": "react-jsx",
        "module": "commonjs",
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "baseUrl": ".",
        "outDir": "dist",
        "moduleResolution": "node",
        "resolveJsonModule": true
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "src/store.js"],
    "exclude": ["node_modules"]
}
